# Environment Configuration Template
# Copy this file to .env in the project root and fill in your actual values
# The .env file is gitignored and should never be committed

# Environment
ENVIRONMENT=Local

# Vectorizer Configuration
# DEFAULT_VECTORIZER: Vectorizer to use by default (text2vec-transformers, text2vec-openai, none)
# VECTORIZER_ENABLED: Set to 'false' to disable vectorizers entirely (uses 'none')
DEFAULT_VECTORIZER=text2vec-transformers
VECTORIZER_ENABLED=true

# Weaviate Configuration
WEAVIATE_URL=http://localhost:8080
# WEAVIATE_KEY is optional for local development (anonymous access enabled in docker-compose)
# Leave empty or remove this line for local dev with docker-compose
WEAVIATE_KEY=

# OpenAI Configuration (OPTIONAL)
# By default, the local docker-compose uses free text2vec-transformers (no API key needed)
# Only set this if you want to use OpenAI's embeddings instead (requires paid API key)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Application Insights (optional - leave empty if not using)
APPINSIGHTS_CONNECTION_STRING=

# Application Settings (optional)
APPLICATION_ID=weaviate-client-local

