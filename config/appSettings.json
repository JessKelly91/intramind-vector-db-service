{
  "Weaviate": {
    "Url": "${WEAVIATE_URL}",
    "ApiKey": "${WEAVIATE_KEY}",
    "DefaultVectorizer": ""
  },
  "OpenAI": {
    "ApiKey": "${OPEN_API_KEY}"
  },
  "ApplicationInsights": {
    "ConnectionString": "${APPINSIGHTS_CONNECTION_STRING}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Environment": {
    "Value": "${ENVIRONMENT}",
    "ApplicationId": ""
  },
  "KeyVault": {
    "VaultUri": "",
    "ManagedIdentityClientId": "",
    "TenantId": "",
    "Enabled": true
  }
}
